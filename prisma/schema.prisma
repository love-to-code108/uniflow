// 1. This tells Prisma to generate a JavaScript library for you
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // Add this line
}


// 2. This is the connection to your Docker container
datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// 3. THE MODELS (Your Database Tables)

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  username String   @unique             // Added for your login form
  password String                       // Added for your login form
  role     String  // "STUDENT", "FACULTY", "ADMIN"
  events   Event[] // Links the User to the Events they create
}


model Event{
  id            String    @id @default(cuid())
  name          String
  description   String
  userId        String
  user          User    @relation(fields:[userId], references:[id])
  date          String
  startTime     String
  endTime       String
  expectedNumberOfStudnets    String
  venue         String

}



