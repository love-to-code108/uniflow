// 1. This tells Prisma to generate a JavaScript library for you
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // Add this line
}


// 2. This is the connection to your Docker container
datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// 3. THE MODELS (Your Database Tables)

model User {
  id              String   @id @default(cuid())
  name            String?
  email           String?   @unique
  username        String   @unique             
  password        String                       
  permissions     Json?  
  events          Event[]
  vehicleRequests   VehicleRequest[]
  
}


model Event{
  id            String    @id @default(cuid())
  name          String
  description   String
  userId        String
  user          User    @relation(fields:[userId], references:[id])
  date          DateTime
  startTime     String
  endTime       String
  expectedNumberOfStudents    Int
  venue         String
  registrationLink    String?
  status String @default("pending")

}



// --- NEW VEHICLE MODELS ---

// The actual physical cars (Admin will add "Vehicle 1", "Vehicle 2", etc.)
model Vehicle {
  id              String           @id @default(cuid())
  name            String           @unique // e.g., "Vehicle 1"
  requests        VehicleRequest[] 
}

// The booking request
model VehicleRequest {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields:[userId], references:[id])
  
  // The specific car they are asking for (Admin can change this ID later)
  vehicleId           String
  vehicle             Vehicle  @relation(fields:[vehicleId], references:[id])
  
  date                DateTime 
  startTime           String
  endTime             String
  destination         String   
  purpose             String
  
  status              String   @default("pending") // "pending", "approved", "rejected"
}



